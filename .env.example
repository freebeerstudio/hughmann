# ─── HughMann Environment Variables ──────────────────────────────────────────
# Copy this file to ~/.hughmann/.env and fill in the values you need.
# Only configure the services you selected during `hughmann setup`.

# ─── Model Providers ────────────────────────────────────────────────────────
# Claude Max: No key needed — authenticates via OAuth on first run.
#   The Claude Agent SDK will open a browser window for consent.
#   Works with any active Claude Max/Pro subscription.

# Claude API (direct, pay-per-token):
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (100+ models, great for light tasks and fallback):
# OPENROUTER_API_KEY=sk-or-...

# OpenAI (GPT, Whisper transcription, embeddings):
# OPENAI_API_KEY=sk-...

# ─── Data Engines ───────────────────────────────────────────────────────────
# SQLite: No config needed — creates a local database automatically.

# Supabase (managed Postgres + vector search):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key

# Turso (cloud SQLite with edge replication):
# TURSO_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# ─── Embeddings ─────────────────────────────────────────────────────────────
# Required for vector memory search. Uses OpenAI-compatible API.
# If OPENAI_API_KEY is set, embeddings use it automatically.
# For other providers (e.g., local Ollama):
# EMBEDDING_API_KEY=your-key
# EMBEDDING_API_URL=http://localhost:11434/api/embeddings
# EMBEDDING_MODEL=nomic-embed-text

# ─── Frontends ──────────────────────────────────────────────────────────────
# Telegram bot:
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# ─── Mail Pipeline ─────────────────────────────────────────────────────────
# macOS Mail.app integration (requires AppleScript permissions):
# MAIL_ACCOUNT=your-email@example.com
# MAIL_MAILBOX=INBOX

# ─── Advanced ───────────────────────────────────────────────────────────────
# Override the default HughMann home directory:
# HUGHMANN_HOME=~/.hughmann
