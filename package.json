{
  "name": "hughmann",
  "version": "0.1.0",
  "description": "Your personal AI operating system",
  "type": "module",
  "bin": {
    "hughmann": "dist/cli.js",
    "create-hughmann": "dist/index.js",
    "hughmann-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "chat": "tsx src/cli.ts chat",
    "setup": "tsx src/cli.ts setup",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "personal-ai",
    "autonomous",
    "agent",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.98.0",
    "@types/node": "^25.3.3",
    "grammy": "^1.41.1",
    "picocolors": "^1.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
