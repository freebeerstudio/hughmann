{
  "name": "create-hughmann",
  "version": "0.1.0",
  "description": "Your personal AI operating system — autonomous agents, memory, domain isolation, and self-improvement",
  "type": "module",
  "bin": {
    "hughmann": "dist/cli.js",
    "create-hughmann": "dist/index.js",
    "hughmann-mcp": "dist/mcp-server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "chat": "tsx src/cli.ts chat",
    "setup": "tsx src/cli.ts setup",
    "build": "tsc && rm -rf dist/skills && cp -r src/skills dist/skills && cp src/calendar/calendar-events.swift dist/calendar/ && swiftc -O src/calendar/calendar-events.swift -o dist/calendar/calendar-events",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/freebeerstudio/hughmann.git"
  },
  "author": "Free Beer Studio <wayne@freebeer.ai>",
  "homepage": "https://github.com/freebeerstudio/hughmann#readme",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "personal-ai",
    "autonomous",
    "agent",
    "claude",
    "create",
    "cli",
    "memory",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@clack/prompts": "^1.1.0",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.98.0",
    "@trigger.dev/sdk": "^4.4.0",
    "better-sqlite3": "^12.6.2",
    "grammy": "^1.41.1",
    "pg": "^8.19.0",
    "picocolors": "^1.1.1",
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "trigger.dev": "^1.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
